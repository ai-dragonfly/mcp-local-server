# =========================================================
# MCP LOCAL SERVER — Example environment configuration
# Copy this file to .env and fill only what you need.
# =========================================================

# ---------------------------------------------------------
# Core server
# ---------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=8000
LOG_LEVEL=INFO
AUTO_RELOAD_TOOLS=1
EXECUTE_TIMEOUT_SEC=180
RELOAD=0

# ---------------------------------------------------------
# Ship Tracker
# ---------------------------------------------------------
# Required only if you want to use ship_tracker.
# Get your key from AISStream and put it here.
AISSTREAM_API_KEY=

# ---------------------------------------------------------
# Office to PDF
# ---------------------------------------------------------
# Preferred conversion engine:
# auto | libreoffice | docx2pdf
OFFICE_TO_PDF_ENGINE=auto

# ---------------------------------------------------------
# Script Executor
# ---------------------------------------------------------
# Optional timeout override for script execution.
SCRIPT_TIMEOUT_SEC=

# Optional maximum number of tool calls allowed per script.
MAX_TOOL_CALLS_PER_SCRIPT=50

# ---------------------------------------------------------
# Dev Navigator
# ---------------------------------------------------------
# Optional repository slug override for release index workflows.
DEVNAV_REPO_SLUG=

# ---------------------------------------------------------
# Lichess
# ---------------------------------------------------------
# Optional delay between public requests.
LICHESS_RATE_LIMIT_DELAY=0.2

# ---------------------------------------------------------
# Vélib'
# ---------------------------------------------------------
# Optional override URLs for the public data sources.
VELIB_STATION_INFO_URL=
VELIB_STATION_STATUS_URL=

# ---------------------------------------------------------
# Advanced runtime
# ---------------------------------------------------------
# Safe JSON / bigint handling options.
BIGINT_AS_STRING=
BIGINT_STR_THRESHOLD=
PY_INT_MAX_STR_DIGITS=

# ---------------------------------------------------------
# Proxy / outbound network
# ---------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ---------------------------------------------------------
# OS / locale convenience
# ---------------------------------------------------------
TZ=UTC
LANG=en_US.UTF-8
