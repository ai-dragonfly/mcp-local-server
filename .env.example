# =========================================================
# MCP LOCAL SERVER — Example environment configuration
# Copy this file to .env and fill only what you need.
# =========================================================

# ---------------------------------------------------------
# Core server
# ---------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=8000
LOG_LEVEL=INFO
AUTO_RELOAD_TOOLS=1
EXECUTE_TIMEOUT_SEC=180

# Optional: force tool/environment reload behavior
RELOAD=0

# ---------------------------------------------------------
# HTTP / networking defaults
# ---------------------------------------------------------
# Optional default timeout for outbound HTTP calls when relevant
HTTP_TIMEOUT_SEC=30

# ---------------------------------------------------------
# News Aggregator
# ---------------------------------------------------------
# NewsAPI (optional)
NEWSAPI_KEY=

# New York Times API (optional)
NYT_API_KEY=

# The Guardian Open Platform API (optional)
GUARDIAN_API_KEY=

# ---------------------------------------------------------
# Academic Research / external knowledge
# ---------------------------------------------------------
# Crossref mailto is recommended for polite API usage
CROSSREF_MAILTO=

# Optional custom user-agent suffix for academic requests
ACADEMIC_RESEARCH_USER_AGENT_SUFFIX=

# ---------------------------------------------------------
# Office to PDF
# ---------------------------------------------------------
# Optional preferred conversion engine:
# auto | libreoffice | docx2pdf
OFFICE_TO_PDF_ENGINE=auto

# Optional path to LibreOffice binary if not in PATH
LIBREOFFICE_PATH=

# ---------------------------------------------------------
# Playwright
# ---------------------------------------------------------
# Optional browser selection if your tool supports it
PLAYWRIGHT_BROWSER=chromium

# Optional default headless mode: true | false
PLAYWRIGHT_HEADLESS=true

# Optional default timeout in ms
PLAYWRIGHT_TIMEOUT_MS=30000

# ---------------------------------------------------------
# Minecraft Control
# ---------------------------------------------------------
MINECRAFT_RCON_HOST=
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=

# ---------------------------------------------------------
# Chess / Stockfish
# ---------------------------------------------------------
# Path to Stockfish binary if not available in PATH
STOCKFISH_PATH=

# ---------------------------------------------------------
# Tool Audit
# ---------------------------------------------------------
# Optional default models for audit flows
TOOL_AUDIT_DEFAULT_MODEL=
TOOL_AUDIT_FUSER_MODEL=

# ---------------------------------------------------------
# Dev Navigator
# ---------------------------------------------------------
# Optional default limits / behavior
DEVNAV_DEFAULT_LIMIT=20
DEVNAV_MAX_FILES_SCANNED=10000
DEVNAV_MAX_BYTES_PER_FILE=65536

# ---------------------------------------------------------
# SQLite / local storage
# ---------------------------------------------------------
# Optional override directories if supported by your implementation
SQLITE_BASE_DIR=sqlite3
PLAYWRIGHT_BASE_DIR=playwright
PDF_DOWNLOAD_DIR=docs/pdfs

# ---------------------------------------------------------
# FFmpeg
# ---------------------------------------------------------
# Optional custom ffmpeg / ffprobe paths
FFMPEG_PATH=
FFPROBE_PATH=

# ---------------------------------------------------------
# Shell / Script Executor
# ---------------------------------------------------------
# Optional default shell
DEFAULT_SHELL=bash

# Optional safety note:
# keep shell/script execution enabled only on trusted local machines
# SHELL_ENABLED=1
# SCRIPT_EXECUTOR_ENABLED=1

# ---------------------------------------------------------
# Proxy / outbound network
# ---------------------------------------------------------
# Optional global proxy settings for some tools if your environment uses them
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ---------------------------------------------------------
# OS / locale convenience
# ---------------------------------------------------------
TZ=UTC
LANG=en_US.UTF-8
