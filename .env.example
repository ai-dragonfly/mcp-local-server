# =========================================================
# MCP LOCAL SERVER — Example environment configuration
# Copy this file to .env and fill only what you need.
# =========================================================

# ---------------------------------------------------------
# Core server
# ---------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=8000
LOG_LEVEL=INFO
AUTO_RELOAD_TOOLS=1
EXECUTE_TIMEOUT_SEC=180

# Optional: force tool/environment reload behavior
RELOAD=0

# ---------------------------------------------------------
# News Aggregator
# ---------------------------------------------------------
# News API (optional)
NEWS_API_KEY=

# New York Times API (optional)
NYT_API_KEY=

# The Guardian Open Platform API (optional)
GUARDIAN_API_KEY=

# ---------------------------------------------------------
# Academic Research
# ---------------------------------------------------------
# Optional runtime output limits
ACADEMIC_RS_MAX_ITEMS=
ACADEMIC_RS_MAX_ABSTRACT_CHARS=
ACADEMIC_RS_MAX_BYTES=

# ---------------------------------------------------------
# Office to PDF
# ---------------------------------------------------------
# Optional preferred conversion engine:
# auto | libreoffice | docx2pdf
OFFICE_TO_PDF_ENGINE=auto

# ---------------------------------------------------------
# Playwright
# ---------------------------------------------------------
# Playwright may require browser installation:
# playwright install

# ---------------------------------------------------------
# Minecraft Control
# ---------------------------------------------------------
# Minecraft Control requires access to a compatible RCON-enabled server.
MINECRAFT_RCON_HOST=
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=

# ---------------------------------------------------------
# Chess / Stockfish / Lichess
# ---------------------------------------------------------
# Path to Stockfish binary if not available in PATH
STOCKFISH_PATH=

# Optional rate-limit spacing for public Lichess requests
LICHESS_RATE_LIMIT_DELAY=0.2

# ---------------------------------------------------------
# Ship Tracker
# ---------------------------------------------------------
AISSTREAM_API_KEY=

# ---------------------------------------------------------
# Script Executor
# ---------------------------------------------------------
SCRIPT_TIMEOUT_SEC=
MAX_TOOL_CALLS_PER_SCRIPT=

# ---------------------------------------------------------
# Dev Navigator
# ---------------------------------------------------------
# Optional repository slug override for release index workflows
DEVNAV_REPO_SLUG=

# ---------------------------------------------------------
# Vélib'
# ---------------------------------------------------------
VELIB_STATION_INFO_URL=
VELIB_STATION_STATUS_URL=

# ---------------------------------------------------------
# Advanced runtime
# ---------------------------------------------------------
# Safe JSON / bigint handling options
BIGINT_AS_STRING=
BIGINT_STR_THRESHOLD=
PY_INT_MAX_STR_DIGITS=

# ---------------------------------------------------------
# Proxy / outbound network
# ---------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ---------------------------------------------------------
# OS / locale convenience
# ---------------------------------------------------------
TZ=UTC
LANG=en_US.UTF-8
